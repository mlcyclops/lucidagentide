# --- harness (Bun/TypeScript) ---
node_modules/
.bun/
*.tsbuildinfo

# --- scanner sidecar (Python/uv) ---
scanner-sidecar/.venv/
**/__pycache__/
*.pyc
.pytest_cache/

# --- vendored omp reference clone (read-only, not part of our source) ---
vendor/
# ...but the desktop renderer's vendored, offline assets (KaTeX CSS + fonts) DO ship.
!desktop/renderer/vendor/
!desktop/renderer/vendor/**

# --- telemetry / databases (raw forensic data stays local, never committed) ---
**/*.duckdb
**/*.duckdb.wal
**/telemetry/raw/
repos/project-alpha/.agent/telemetry/

# --- generated dashboard data (materialized from DuckDB) ---
observable/docs/data/
observable/.observablehq/cache/

# --- OS / editor ---
.DS_Store
Thumbs.db

# --- local Claude Code settings (personal; shared config lives in settings.json) ---
.claude/settings.local.json
# Agent worktrees (isolated per-agent repo copies) — transient, never commit them
.claude/worktrees/

# desktop electron app
desktop/node_modules/
desktop/dist/

# --- secrets / credentials (NEVER commit keys or tokens) ---
lucid-gui.json
**/lucid-gui.json
lucid-agents.json
**/lucid-agents.json
.env
.env.*
*.env
**/*.key
**/*.pem
**/*.pfx
**/*.p12
**/*.cer
**/*.mobileprovision
*secret*
*credentials*
**/auth.json
# ...but these are first-party SOURCE files (the Agent Builder secret guardrail), not secrets:
!**/secret_guard.ts
!**/secret_guard.test.ts

# desktop electron-builder output
desktop/release/

# generated app icons (source of truth is desktop/build/icon.svg;
# the `icons` script / CI regenerates these from it)
desktop/build/icon.png
desktop/build/icon.ico
desktop/build/icon.icns

# bundled runtime binaries (bun/uv) — downloaded per-OS by CI, never committed
desktop/runtimes/*
!desktop/runtimes/.gitkeep
!desktop/runtimes/README.md

# Local-only: contains real personal data (PII) — never commit
tools/seed_personal_facts.ts

# P-EXT.4: compiled lucid launcher (built during desktop dist)
/bin/
netwatch.log

# P-KG-CODE.1: generated per-workspace code-graph cache (the tracked .omp/commands stays)
.omp/codegraph.json
.omp/codegraph-symbol.json
# P-AGENT.2b: per-workspace authored Agent Builder specs (runtime data, not source)
.omp/agents/
# P-AGENT.6: exported agent bundles (generated artifacts)
.omp/agent-exports/
# P-AGENT.4-live: materialized agent run dirs (generated artifacts)
.omp/agent-runs/
