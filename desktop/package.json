{
  "name": "lucidagentide-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Electron desktop shell for LucidAgentIDE + omp — gated agent chat + live security/memory dashboards.",
  "main": "dist/main.js",
  "scripts": {
    "build": "bun build main.ts --target=node --format=cjs --external electron --outfile dist/main.js && bun build preload.ts --target=node --format=cjs --external electron --outfile dist/preload.js",
    "icons": "bun run build/make-icons.ts",
    "runtimes:mac": "bun run build/fetch-runtimes.ts",
    "start": "bun run build && electron .",
    "web": "bun run dev.ts",
    "typecheck": "tsc --noEmit",
    "dist:mac": "bun run runtimes:mac && bun run icons && bun run build && electron-builder --mac --publish never",
    "dist:win": "bun run icons && bun run build && electron-builder --win --publish never",
    "dist:linux": "bun run icons && bun run build && electron-builder --linux --publish never",
    "dist": "bun run icons && bun run build && electron-builder --publish never"
  },
  "build": {
    "appId": "com.lucidagentide.desktop",
    "productName": "LucidAgentIDE",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": ["dist/**", "renderer/**", "package.json"],
    "asarUnpack": [],
    "extraResources": [
      {
        "from": "runtimes",
        "to": "runtimes",
        "filter": ["**/*", "!README.md", "!.gitkeep"]
      },
      {
        "from": "..",
        "to": "repo",
        "filter": [
          "harness/**/*",
          "tools/**/*",
          "scanner-sidecar/**/*",
          "!scanner-sidecar/.venv/**",
          "!**/__pycache__/**",
          "desktop/*.ts",
          "desktop/renderer/**/*",
          "desktop/package.json",
          "node_modules/**/*",
          "package.json",
          "!desktop/node_modules/**",
          "!desktop/release/**",
          "!desktop/dist/**",
          "!**/.git/**"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png",
      "identity": null,
      "artifactName": "${productName}-mac-${arch}.${ext}",
      "target": [
        {
          "target": "zip",
          "arch": ["arm64", "x64"]
        }
      ],
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "gatekeeperAssess": false
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LucidAgentIDE",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "artifactName": "${productName}-Setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-portable.${ext}"
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Development",
      "target": ["AppImage"]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "mlcyclops",
        "repo": "lucidagentide"
      }
    ]
  },
  "dependencies": {
    "@types/katex": "^0.16.8",
    "electron-updater": "^6.3.9",
    "katex": "^0.17.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "typescript": "^5.6.0"
  }
}
