{
  "name": "lucidagentide-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Electron desktop shell for LucidAgentIDE + omp — gated agent chat + live security/memory dashboards.",
  "main": "dist/main.js",
  "scripts": {
    "build": "bun build main.ts --target=node --format=cjs --external electron --outfile dist/main.js && bun build preload.ts --target=node --format=cjs --external electron --outfile dist/preload.js",
    "start": "bun run build && electron .",
    "web": "bun run dev.ts",
    "typecheck": "tsc --noEmit",
    "dist:mac": "bun run build && electron-builder --mac",
    "dist": "bun run build && electron-builder"
  },
  "build": {
    "appId": "com.lucidagentide.desktop",
    "productName": "LucidAgentIDE",
    "directories": { "output": "release", "buildResources": "build" },
    "files": ["dist/**", "renderer/**", "package.json"],
    "asarUnpack": [],
    "extraResources": [
      {
        "from": "..",
        "to": "repo",
        "filter": [
          "harness/**/*",
          "tools/**/*",
          "scanner-sidecar/**/*",
          "!scanner-sidecar/.venv/**",
          "!**/__pycache__/**",
          "desktop/*.ts",
          "desktop/renderer/**/*",
          "desktop/package.json",
          "node_modules/**/*",
          "package.json"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "gatekeeperAssess": false
    },
    "dmg": { "title": "LucidAgentIDE ${version}" }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.0"
  }
}
